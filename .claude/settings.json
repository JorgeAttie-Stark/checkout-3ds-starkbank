{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-direct-commit.sh",
            "statusMessage": "Gitflow: checando branch antes de commit..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-push-gate.sh",
            "timeout": 300,
            "statusMessage": "Pre-push: build + test + smoke..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/mpi-cleanup-reminder.sh"
          }
        ]
      }
    ]
  }
}
